# ============================================================
# ENVIRONMENT VARIABLES - Next.js Dashboard
# ============================================================

# Flask API (REQUIRED) - Your Flask backend URL
# For local development: http://localhost:5000
# For production: https://your-domain.com
# For tunnel: https://your-tunnel-url.com
NEXT_PUBLIC_FLASK_API_URL=https://your-flask-api-url.com

# OPTIONAL: Supabase Configuration (only needed if you want to use Supabase)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
