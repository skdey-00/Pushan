<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f172a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e293b;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Traffic Light -->
  <g transform="translate(100, 100)">
    <rect x="0" y="0" width="120" height="320" rx="20" fill="#334155"/>
    <circle cx="60" cy="60" r="45" fill="#ef4444" opacity="0.9"/>
    <circle cx="60" cy="160" r="45" fill="#eab308" opacity="0.9"/>
    <circle cx="60" cy="260" r="45" fill="#22c55e" opacity="0.9"/>
  </g>

  <!-- Title -->
  <text x="600" y="180" font-family="Arial, sans-serif" font-size="72" font-weight="bold" fill="#ffffff" text-anchor="middle">
    Adaptive Traffic Signal
  </text>
  <text x="600" y="260" font-family="Arial, sans-serif" font-size="56" font-weight="normal" fill="#94a3b8" text-anchor="middle">
    Dashboard
  </text>

  <!-- Features -->
  <g transform="translate(300, 320)">
    <text x="0" y="40" font-family="Arial, sans-serif" font-size="32" fill="#22c55e">✓</text>
    <text x="50" y="45" font-family="Arial, sans-serif" font-size="28" fill="#cbd5e1">Real-time AI Detection</text>
  </g>
  <g transform="translate(300, 380)">
    <text x="0" y="40" font-family="Arial, sans-serif" font-size="32" fill="#3b82f6">✓</text>
    <text x="50" y="45" font-family="Arial, sans-serif" font-size="28" fill="#cbd5e1">YOLOv8 Vehicle Counting</text>
  </g>
  <g transform="translate(300, 440)">
    <text x="0" y="40" font-family="Arial, sans-serif" font-size="32" fill="#eab308">✓</text>
    <text x="50" y="45" font-family="Arial, sans-serif" font-size="28" fill="#cbd5e1">Adaptive Signal Control</text>
  </g>

  <!-- URL -->
  <text x="600" y="580" font-family="Arial, sans-serif" font-size="24" fill="#64748b" text-anchor="middle">
    web-three-red-50.vercel.app
  </text>
</svg>
